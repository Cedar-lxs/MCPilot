# ==========================================
# MCPilot 环境配置模板
# 复制为 .env 并填入你的 API Key
# ==========================================

# === LLM 配置（支持 OpenAI 兼容 API） ===
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# === Embedding 配置（阿里云 DashScope） ===
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=sk-your-dashscope-api-key
EMBEDDING_MODEL=text-embedding-v3

# === 向量库（ChromaDB 本地持久化路径） ===
CHROMA_DB_PATH=./chroma_data

# === 会话数据库（SQLite 本地持久化路径） ===
SESSION_DB_PATH=./data/mcpilot.db

# === API 认证 ===
# 设置后所有 API 请求必须携带 Authorization: Bearer <key>
# 留空则关闭认证（仅本地开发使用）
API_SECRET_KEY=

# === RAG 参数 ===
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3

# === Agent 参数 ===
MAX_ITERATIONS=10
AGENT_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
